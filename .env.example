# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/po_mgmt

# App Secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# Google OAuth2 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# JWT
JWT_SECRET_KEY=jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Google Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# MongoDB (optional - for AI description logs)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=po_mgmt_ai_logs

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
